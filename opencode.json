{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "perplexity-pro": {
      "npm": "@ai-sdk/perplexity-pro",
      "options": {
        "baseURL": "https://api.perplexity.ai/chat/completions",

        "aplKey": "{env:PERPLEXITY_API_KEY}"
      },
      "models": {
        "perplexity-pro/sonar-pro": {
          "name": "Dragonfly 1.5 Pro"
        }
      }
    },
    "opencode": {
      "models": {
        "big-pickle": {
          "options": {
            "reasoningEffort": "high"
          }
        }
      }
    },
    "zai-coding-plan": {
      "models": {
        "glm-4.6": {
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },

        "glm-4.5": {
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "glm-4.5v": {
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      }
    }
  },
  "mcp": {
    "promethean-github": {
      "type": "remote",
      "url": "http://localhost:4320/github",
      "enabled": true
    },
    "clj-kondo": {
      "type": "local",
      "command": ["npx", "clj-kondo-mcp"],
      "enabled": true
    }
  },

  "instructions": [
    "./packages/*/AGENTS.md",
    "./cli/AGENTS.md",
    "./services/AGENTS.md",
    "./experimental/AGENTS.md",
    "./tools/AGENTS.md",
    "./scripts/AGENTS.md"
  ]
}
