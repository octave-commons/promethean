{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode": {
      "models": {
        "big-pickle": {
          "options": {
            "reasoningEffort": "high"
          }
        }
      }
    },
    "zai-coding-plan": {
      "models": {
        "glm-4.6": {
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },

        "glm-4.5": {
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "glm-4.5v": {
          "options": {
            "thinking": {
              "type": "enabled"
            }
          }
        }
      }
    }
  },
  "instructions": [
    "./packages/*/AGENTS.md",
    "./cli/AGENTS.md",
    "./services/AGENTS.md",
    "./experimental/AGENTS.md",
    "./tools/AGENTS.md",
    "./scripts/AGENTS.md"
  ]
}
