{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": false,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["vitest/globals", "node"],
    "paths": {
      "@promethean-os/knowledge-graph": ["../../services/knowledge-graph/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.test.ts"],
  "exclude": ["dist"]
}
