{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "kanban-plugin-git-index",
  "projectType": "library",
  "sourceRoot": "packages/kanban-plugin-git-index/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban-plugin-git-index run build"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban-plugin-git-index run typecheck"
      }
    }
  }
}
