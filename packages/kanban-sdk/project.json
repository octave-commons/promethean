{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "kanban-sdk",
  "projectType": "library",
  "sourceRoot": "packages/kanban-sdk/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban-sdk run build"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban-sdk run typecheck"
      }
    }
  }
}
