{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "kanban-plugin-content",
  "projectType": "library",
  "sourceRoot": "packages/kanban-plugin-content/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban-plugin-content run build"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban-plugin-content exec ava --config=ava.config.mjs"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban-plugin-content run typecheck"
      }
    }
  }
}
