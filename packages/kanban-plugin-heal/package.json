{
  "name": "@promethean-os/kanban-plugin-heal",
  "version": "0.1.0",
  "description": "Healing/Scar plugin for Promethean Kanban (scaffold)",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test dist/tests/git-tag-manager.test.js"
  },
  "dependencies": {
    "@promethean-os/kanban-sdk": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0"
  }
}
