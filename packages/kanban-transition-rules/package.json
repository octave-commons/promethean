{
  "name": "@promethean-os/kanban-transition-rules",
  "version": "0.1.0",
  "description": "Transition rules and DSL bridge extracted from kanban",
  "type": "module",
  "main": "dist/src/index.cjs",
  "module": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.cjs"
    },
    "./transition-rules": {
      "types": "./dist/src/transition-rules.d.ts",
      "import": "./dist/src/transition-rules.js"
    },
    "./transition-rules-functional": {
      "types": "./dist/src/transition-rules-functional.d.ts",
      "import": "./dist/src/transition-rules-functional.js"
    },
    "./safe-rule-evaluation": {
      "types": "./dist/src/safe-rule-evaluation.d.ts",
      "import": "./dist/src/safe-rule-evaluation.js"
    },
    "./testing-transition/*": {
      "types": "./dist/src/testing-transition/*.d.ts",
      "import": "./dist/src/testing-transition/*.js"
    },
    "./pantheon/*": {
      "types": "./dist/src/pantheon/*.d.ts",
      "import": "./dist/src/pantheon/*.js"
    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "import": "./dist/src/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run clean && tsc -b tsconfig.json --force && cp -r src/nbb dist/nbb && cp -r tests/nbb dist/tests/nbb",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && ava --config ../../config/ava.config.mjs"
  },
  "dependencies": {
    "@promethean-os/kanban-sdk": "workspace:*",
    "@promethean-os/pantheon": "workspace:*",
    "@promethean-os/pantheon-core": "workspace:*",
    "nbb": "^1.3.204",
    "yaml": "^2.5.0",
    "js-yaml": "^4.0.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/js-yaml": "^4.0.9",
    "@types/xml2js": "^0.4.14",
    "esmock": "^2.6.0"
  }
}
