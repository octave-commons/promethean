{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "kanban-transition-rules",
  "projectType": "library",
  "sourceRoot": "packages/kanban-transition-rules/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban-transition-rules run build"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban-transition-rules exec ava --config=ava.config.mjs"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban-transition-rules run typecheck"
      }
    }
  }
}
